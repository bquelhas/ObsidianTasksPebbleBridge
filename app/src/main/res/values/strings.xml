    <string name="section_auto_open">Automatic vault refresh</string>
    <string name="auto_open_obsidian">Open Obsidian automatically before each sync</string>
    <string name="auto_open_hint">The app briefly opens Obsidian so Obsidian Sync pulls the latest vault, updates the watch, then returns to the home screen. While the phone is locked Android blocks this, so it runs right after you unlock instead, at the frequency chosen above.</string>
    <string name="perm_overlay_title">Permission needed</string>
    <string name="perm_overlay_msg">To open Obsidian for you, Android requires the "Display over other apps" permission.\n\nOn the next screen, turn it on for this app. Nothing is ever drawn over other apps — the permission is only what lets an app launch another one from the background.\n\nWithout it the watch still updates, but only with what is already on the phone.</string>
    <string name="perm_overlay_grant">Grant permission</string>
    <string name="perm_overlay_later">Not now</string>
    <string name="shizuku_mode">Invisible mode (Shizuku)</string>
    <string name="shizuku_hint">If you have Shizuku set up, open Obsidian silently in the background — even while the phone is locked, with no pop-up. Otherwise leave this off and the visible method above is used.</string>
    <string name="shizuku_title">Shizuku</string>
    <string name="shizuku_not_found">Shizuku isn\'t running. Install the Shizuku app and start its service, then turn this on again.</string>
    <string name="shizuku_denied">Shizuku permission denied — invisible mode stays off.</string>
    <string name="shizuku_error">Couldn\'t reach Shizuku. Make sure it\'s installed and running.</string>
