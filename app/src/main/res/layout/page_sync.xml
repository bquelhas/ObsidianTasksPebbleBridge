<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="24dp">

        <!-- Card: Activity log -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.App.CardView.NoPadding"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="12dp">

                    <TextView
                        style="@style/Widget.App.SectionLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/section_log" />

                    <ImageButton
                        android:id="@+id/btnClearLog"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:padding="8dp"
                        android:src="@drawable/ic_clear"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/action_clear_log"
                        app:tint="?attr/colorPrimary" />

                    <ImageButton
                        android:id="@+id/btnCopyLog"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:padding="8dp"
                        android:src="@drawable/ic_copy"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/action_copy_log"
                        app:tint="?attr/colorPrimary" />

                </LinearLayout>

                <ScrollView
                    android:id="@+id/scrollLog"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:background="@drawable/bg_mono">

                    <TextView
                        android:id="@+id/txtLog"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/log_initial"
                        android:textAppearance="@style/TextAppearance.App.Mono"
                        android:textColor="@color/vault_dark_on_surface"
                        android:padding="16dp" />
                </ScrollView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card: Sync settings -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.App.CardView.NoPadding"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/Widget.App.SectionLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/section_settings"
                    android:paddingBottom="14dp" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.App.TextField.Dropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="@string/hint_sync_interval">

                    <AutoCompleteTextView
                        android:id="@+id/spinnerSyncInterval"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.App.TextField"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="@string/hint_max_tasks">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtMaxTasks"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:maxLength="2" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.App.TextField"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:hint="@string/hint_evening_hour">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtEveningHour"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLength="2" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.App.TextField"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:hint="@string/hint_morning_hour">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtMorningHour"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLength="2" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card: automatic vault refresh (auto-open Obsidian) -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.App.CardView.NoPadding"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/Widget.App.SectionLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/section_auto_open"
                    android:paddingBottom="12dp" />

                <!-- The app opens Obsidian itself so Obsidian Sync can pull the
                     latest vault (needs the overlay permission). -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchAutoOpenObsidian"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_open_obsidian"
                    android:paddingBottom="6dp" />

                <!-- How often the launch may actually happen — decoupled from the
                     (much shorter) watch-refresh interval, which is invisible. -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilObsidianOpen"
                    style="@style/Widget.App.TextField.Dropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:hint="@string/hint_obsidian_open_freq">

                    <AutoCompleteTextView
                        android:id="@+id/spinnerObsidianOpen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Optional Shizuku "invisible mode": launch Obsidian in the
                     background (even while locked) with no pop-up. -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchShizuku"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/shizuku_mode"
                    android:paddingBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/shizuku_hint"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:paddingBottom="14dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_open_hint"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:paddingBottom="14dp" />

                <!-- Tip row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_tip_row"
                    android:padding="14dp"
                    android:layout_marginTop="8dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="12dp"
                        android:src="@drawable/ic_lightbulb"
                        android:contentDescription="@null"
                        app:tint="?attr/colorPrimary" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_open_tip"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Large primary action: Send tasks to Pebble -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSync"
            style="@style/Widget.App.Button.Large"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_sync"
            app:icon="@drawable/ic_tab_sync" />

        <!-- About / GitHub -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAbout"
            style="@style/Widget.App.Button.Text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:text="@string/btn_about"
            app:icon="@drawable/ic_info" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
